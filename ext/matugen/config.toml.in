# Matugen template configuration: maps input templates to output paths for all themed apps
# NOTE: This file is generated by the setup script from config.toml.in + config.json integrations.
# Edit config.toml.in for template structure, config.json integrations for output paths.
[config]
reload_apps = false

# Quickshell MD3 color palette
[templates.skwd]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/quickshell-colors.json"
output_path = "~/.cache/skwd/colors.json"

# Niri focus-ring primary color
[templates.niri-primary]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/niri-colors.kdl"
output_path = "~/.cache/skwd/niri-primary-color"

# App-specific theme templates
[templates.kitty]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/kitty.conf"
output_path = "@OUTPUT_KITTY@"

[templates.kde]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/kde-colors.colors"
output_path = "@OUTPUT_KDE@"

[templates.vscode]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/vscode-theme.json"
output_path = "@OUTPUT_VSCODE@"

[templates.vesktop]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/vesktop.css"
output_path = "@OUTPUT_VESKTOP@"

[templates.zen]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/zen.css"
output_path = "@OUTPUT_ZEN@"

[templates.spicetify]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/spicetify.ini"
output_path = "@OUTPUT_SPICETIFY@"

[templates.yazi]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/yazi-theme.toml"
output_path = "@OUTPUT_YAZI@"

[templates.spicetify-css]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/spicetify.css"
output_path = "@OUTPUT_SPICETIFYCSS@"

[templates.qt6ct]
input_path = "@SKWD_INSTALL@/ext/matugen/templates/qt6ct-colors.conf"
output_path = "@OUTPUT_QT6CT@"
